# Desktop app — sync configuration
#
# URL of the remote backend (used by the CRDT sync engine).
# When the backend is unreachable, the app stays fully functional in offline
# mode and queues writes for the next online cycle.

VITE_API_BASE_URL=http://localhost:8080/api

# Optional: dev-only proxy when running `npm run dev` from the desktop folder.
VITE_API_PROXY_TARGET=http://localhost:8080
