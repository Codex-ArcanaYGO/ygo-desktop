{
  "compilerOptions": {
    "target": "ES2021",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "types": ["node"],
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "react": ["./node_modules/preact/compat/"],
      "react-dom": ["./node_modules/preact/compat/"],
      "@shared/*": ["../ygo-shared/src/*"]
    }
  },
  "include": [
    "src",
    "vite.config.ts",
    "../ygo-shared/src",
    "../ygo-shared/test",
    "../ygo-shared/src/types/css-modules.d.ts"
  ]
}
